# ============================================================
# Ghana SHS Backend — Environment Variables
# Copy to .env and fill in all values before starting.
# NEVER commit .env to version control.
# ============================================================

# ── Database (Neon PostgreSQL) ────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
# Use the "pooled" connection string for the app
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/ghana_shs?sslmode=require"

# Shadow DB required for `prisma migrate dev` in local dev only
# Use a separate Neon branch or local Postgres for this
DATABASE_SHADOW_URL="postgresql://user:password@localhost:5432/ghana_shs_shadow"

# ── JWT Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars-change-this"
JWT_EXPIRES_IN="8h"

# ── CORS — Frontend URL ───────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
FRONTEND_URL="https://wamanafo-shs.vercel.app"

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── SMS (optional — set SMS_PROVIDER=stub to disable) ────────
SMS_PROVIDER="stub"
# SMS_PROVIDER="arkesel"
# SMS_PROVIDER="hubtel"
SMS_API_KEY=""
SMS_SENDER_ID="WamanafoSHS"

# ── File Storage (optional) ───────────────────────────────────
STORAGE_PROVIDER="stub"
# STORAGE_PROVIDER="s3"
# STORAGE_PROVIDER="r2"
STORAGE_BUCKET=""
STORAGE_REGION="us-east-1"
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
