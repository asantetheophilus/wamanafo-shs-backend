# ============================================================
# Wamanafo SHS Backend — Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# Database (Neon / Supabase / Render Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/wamanafo_shs
DATABASE_SHADOW_URL=postgresql://user:pass@host:5432/wamanafo_shs_shadow

# JWT Auth
JWT_SECRET=change-this-to-a-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=8h

# Frontend URL (for reset links and CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Backend public URL (for logo URLs in email/API)
BACKEND_PUBLIC_URL=https://your-backend.onrender.com

# SMTP Email (reset password emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@wamanafo-shs.edu.gh
SMTP_FROM_NAME=Wamanafo SHS

# Logo/file storage (local path, for Render disk)
LOGO_STORAGE_PATH=/app/public/logos

# Optional: S3/R2 storage (if using cloud storage instead)
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=your-bucket
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY_ID=...
# STORAGE_SECRET_ACCESS_KEY=...

# Server
PORT=4000
NODE_ENV=production
